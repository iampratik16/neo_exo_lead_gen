# Neo Eco Cleaning — Lead Generator
# ==================================
# Copy this file to .env and fill in your values.
#
# The scraper uses Playwright for direct Google Maps scraping,
# so no external API keys are required by default.

# Optional: SerpAPI key (alternative to Playwright scraping)
# SERPAPI_KEY=your_serpapi_key_here

# Optional: Hunter.io API key (for email verification)
# HUNTER_API_KEY=your_hunter_io_key_here

# Optional: Apollo.io API key (for contact enrichment)
# APOLLO_API_KEY=your_apollo_io_key_here
